generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
  // provider = "mysql"
}

model User {
  id String @default(uuid()) @id
  Phone String @unique
  orders Order[]
}

model Product {
  id Int @default(autoincrement()) @id
  name String
  stock Int
  imageUrl String
  price Float
  flashSales FlashSale[]
  orders Order[]
}
model FlashSale {
  id Int @default(autoincrement()) @id
  productId Int
  startDate DateTime
  endDate DateTime
  discount Int
  product Product @relation(fields: [productId], references: [id])

}

model Order {
  id        Int     @id @default(autoincrement())
  userId    String
  productId Int

  product Product @relation(fields: [productId], references: [id])
  user User @relation(fields: [userId], references: [id])
}